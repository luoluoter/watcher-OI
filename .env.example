# Upstream watcher bridge endpoint
WATCHER_TARGET=http://172.22.1.82:18789

# Added as Authorization when this service calls upstream.
# Supports raw token or full "Bearer xxx".
WATCHER_AUTH_TOKEN=replace-with-upstream-token

# Simple inbound auth for device -> this service.
# If empty, inbound auth is disabled.
# Supports raw token or full "Bearer xxx".
WATCHER_INBOUND_AUTH_TOKEN=replace-with-inbound-token

# Default sender query fallback
WATCHER_SENDER=test-device

# Runtime limits
WATCHER_UPSTREAM_TIMEOUT_MS=60000
WATCHER_MAX_REQUEST_BYTES=20971520

# Debug outputs
WATCHER_DEBUG_DIR=debug-responses
WATCHER_SAVE_REQ=1
WATCHER_SAVE_RESP=1
WATCHER_SAVE_AUDIO=1
WATCHER_SAVE_UPSTREAM=1
